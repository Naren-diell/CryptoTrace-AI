# ===== Server =====
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ===== Database (MySQL) =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=cryptotrace_ai

# ===== JWT =====
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ===== Blockchain APIs =====
# Get free key at https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key
# Get free key at https://blockchair.com/api
BLOCKCHAIR_API_KEY=your_blockchair_api_key
# blockchain.com API generally does not require a key for basic endpoints
BLOCKCHAIN_INFO_BASE_URL=https://blockchain.info

# ===== AI Layer (optional - falls back to rule-based engine if absent) =====
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
